# ProfitLens local-only Docker Compose settings.
# Copy this file to .env for local development.

POSTGRES_USER=profitlens
POSTGRES_PASSWORD=profitlens_local_password
POSTGRES_DB=profitlens
POSTGRES_HOST_PORT=55432

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_local_password

PGADMIN_DEFAULT_EMAIL=admin@profitlens.com
PGADMIN_DEFAULT_PASSWORD=pgadmin_local_password

JWT_SECRET=profitlens-local-development-secret-change-before-production
